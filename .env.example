# ─── Database (PostgreSQL - Neon) ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ─── Admin Authentication ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeThisPassword123!

# ─── Crypto Wallets ──────────────────────────────────────────────────────────
# Replace with your actual wallet addresses
NEXT_PUBLIC_WALLET_BTC=bc1q...your_bitcoin_address
NEXT_PUBLIC_WALLET_ETH=0x...your_ethereum_address
NEXT_PUBLIC_WALLET_USDT=T...your_usdt_trc20_address

# ─── JWT Secret ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production

# ─── Crypto Gateway (NOWPayments) ────────────────────────────────────────────
# Get from: https://nowpayments.io/dashboard
CRYPTO_GATEWAY_API_KEY=your-nowpayments-api-key
CRYPTO_WEBHOOK_SECRET=your-webhook-secret

# ─── Email Service (Resend) ──────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
EMAIL_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# ─── Discord Webhook (Optional - Stock Alerts) ───────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-token

# ─── Telegram Support (Optional) ─────────────────────────────────────────────
TELEGRAM_SUPPORT_USERNAME=@your_telegram_username

# ─── Download Links ──────────────────────────────────────────────────────────
DOWNLOAD_LINK_VALIDITY_HOURS=24
DOWNLOAD_LINK_MAX_USES=3

# ─── Stock Alerts ────────────────────────────────────────────────────────────
LOW_STOCK_ALERT_THRESHOLD_350=5
LOW_STOCK_ALERT_THRESHOLD_500=5

# ─── App Settings ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
